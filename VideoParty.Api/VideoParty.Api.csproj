    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>d6e7a1cd-6e13-4d7b-8d30-84bb6bafbf71</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.9" />
